rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Allow users to read and write only their own document in the 'users' collection
    // Admins can read and update all users (for upgrading/downgrading)
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    
    // Agents collection: Public read, Admin write
    match /agents/{agentId} {
      allow read: if true;
      allow write, delete: if request.auth != null && isAdmin();
    }
    
    // Reviews collection: Public read, User create, Admin/Author delete
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.authorId || isAdmin());
    }
    
    // Default fallback: Admins only
    match /{document=**} {
      allow read, write: if request.auth != null && isAdmin();
    }
  }
}
